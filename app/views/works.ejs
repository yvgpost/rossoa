<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Práce - Rossoa Tracker</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="ct-root">

  <%- include('_header', { pageTitle: 'Práce', activePage: 'works' }) %>

  <div class="ct-filter-bar">
    <select onchange="window.location.href='/works' + (this.value ? '?construction_id=' + this.value : '')">
      <option value="">Všechny stavby</option>
      <% constructions.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= selectedConstruction == c.id ? 'selected' : '' %>><%= c.name %></option>
      <% }); %>
    </select>
  </div>

  <div class="ct-section" style="margin-top:16px;">
    <button class="ct-section-add" onclick="openAddModal()">
      <span class="ct-add-icon">+</span> Přidat práci
    </button>

    <% if (works.length === 0) { %>
      <div class="ct-empty">Žádné práce nejsou přidány</div>
    <% } else { %>
      <div class="ct-card-list">
        <% works.forEach(function(w) { %>
        <div class="ct-card">
          <div class="ct-card-row">
            <div class="ct-card-main">
              <div class="ct-card-name"><%= w.type %><% if (w.worker_name) { %>, <%= w.worker_name %><% } %></div>
              <div class="ct-card-sub"><%= w.construction_name %> · <%= new Date(w.date).toLocaleDateString('cs-CZ') %></div>
            </div>
            <div class="ct-card-value"><%= parseFloat(w.price).toLocaleString('cs-CZ') %> Kč</div>
          </div>
          <div class="ct-card-actions">
            <button class="ct-edit-btn" style="flex:1;" onclick="openEditModal(<%= w.id %>, <%= w.construction_id %>, '<%= w.date ? new Date(w.date).toISOString().split('T')[0] : '' %>', '<%= w.type.replace(/'/g, "\\'") %>', <%= w.worker_id || 'null' %>, '<%= (w.worker_name||'').replace(/'/g, "\\'") %>', '<%= (w.construction_name||'').replace(/'/g, "\\'") %>', <%= w.price %>)">
              <svg class="ct-edit-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 2l3 3-8 8H3v-3l8-8z"/></svg>
              Upravit
            </button>
            <form method="POST" action="/works/delete/<%= w.id %>" onsubmit="return confirm('Smazat záznam?');" style="flex:1;">
              <button type="submit" class="ct-del-btn" style="width:100%;">Smazat</button>
            </form>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<!-- Add Modal -->
<div class="ct-modal-backdrop" id="add-modal">
  <div class="ct-modal">
    <div class="ct-modal-title">Nová práce</div>
    <form method="POST" action="/works">
      <div class="ct-field">
        <label>Stavba</label>
        <select name="construction_id" required>
          <option value="">-- Vyberte stavbu --</option>
          <% constructions.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= selectedConstruction == c.id ? 'selected' : '' %>><%= c.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="ct-field">
        <label>Typ práce</label>
        <input type="text" name="type" required>
      </div>
      <div class="ct-field">
        <label>Zaměstnanec</label>
        <select name="worker_id">
          <option value="">-- Bez zaměstnance --</option>
          <% workers.forEach(function(w) { %>
            <option value="<%= w.id %>"><%= w.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="ct-field">
        <label>Datum</label>
        <input type="date" name="date" id="add-date" required>
      </div>
      <div class="ct-field">
        <label>Cena (Kč)</label>
        <input type="number" name="price" step="0.01" min="0" required>
      </div>
      <div class="ct-modal-actions">
        <button type="button" class="ct-btn" onclick="closeAddModal()">Zrušit</button>
        <button type="submit" class="ct-btn ct-btn-primary">Uložit</button>
      </div>
    </form>
  </div>
</div>

<!-- Edit Modal -->
<div class="ct-modal-backdrop" id="edit-modal">
  <div class="ct-modal">
    <div class="ct-modal-title">Upravit práci</div>
    <form method="POST" action="/works">
      <input type="hidden" name="id" id="edit-id">
      <div class="ct-field">
        <label>Stavba</label>
        <select name="construction_id" id="edit-construction" required>
          <option value="">-- Vyberte stavbu --</option>
          <% constructions.forEach(function(c) { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="ct-field">
        <label>Typ práce</label>
        <input type="text" name="type" id="edit-type" required>
      </div>
      <div class="ct-field">
        <label>Zaměstnanec</label>
        <select name="worker_id" id="edit-worker">
          <option value="">-- Bez zaměstnance --</option>
          <% workers.forEach(function(w) { %>
            <option value="<%= w.id %>"><%= w.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="ct-field">
        <label>Datum</label>
        <input type="date" name="date" id="edit-date" required>
      </div>
      <div class="ct-field">
        <label>Cena (Kč)</label>
        <input type="number" name="price" id="edit-price" step="0.01" min="0" required>
      </div>
      <div class="ct-modal-actions">
        <button type="button" class="ct-btn" onclick="closeEditModal()">Zrušit</button>
        <button type="submit" class="ct-btn ct-btn-primary">Uložit</button>
      </div>
    </form>
  </div>
</div>

<script src="/app.js"></script>
<script>
function openAddModal() {
  document.getElementById('add-date').value = new Date().toLocaleDateString('en-CA');
  document.getElementById('add-modal').classList.add('show');
}
function closeAddModal() { document.getElementById('add-modal').classList.remove('show'); }

function openEditModal(id, constructionId, date, type, workerId, workerName, constructionName, price) {
  document.getElementById('edit-id').value = id;
  document.getElementById('edit-date').value = date;
  document.getElementById('edit-type').value = type;
  document.getElementById('edit-price').value = price;

  const cSel = document.getElementById('edit-construction');
  const cOpt = Array.from(cSel.options).find(o => o.value == constructionId);
  if (cOpt) { cSel.value = constructionId; }
  else if (constructionName) { cSel.add(new Option(constructionName, constructionId, true, true)); }

  const wSel = document.getElementById('edit-worker');
  const wOpt = Array.from(wSel.options).find(o => o.value == workerId);
  if (wOpt) { wSel.value = workerId; }
  else if (workerName) { wSel.add(new Option(workerName, workerId, true, true)); }
  else { wSel.value = ''; }

  document.getElementById('edit-modal').classList.add('show');
}
function closeEditModal() { document.getElementById('edit-modal').classList.remove('show'); }
document.getElementById('add-modal').addEventListener('click', function(e) { if (e.target === this) closeAddModal(); });
document.getElementById('edit-modal').addEventListener('click', function(e) { if (e.target === this) closeEditModal(); });
</script>
</body>
</html>
