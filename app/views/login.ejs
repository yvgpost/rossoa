<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Přihlášení - Rossoa Tracker</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="ct-login-page">
  <div class="ct-login-box">
    <div class="ct-login-title">Stavební deník</div>
    <div class="ct-login-sub">ROSSOA s.r.o.</div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="ct-alert error" style="margin-bottom:16px;"><%= error %></div>
    <% } %>
    <div id="passkey-error" class="ct-alert error" style="display:none;margin-bottom:16px;"></div>

    <button type="button" class="ct-btn-passkey" id="passkeyBtn" onclick="loginWithPasskey()">
      🔑 Face ID / Touch ID
    </button>

    <div class="ct-login-divider"><span>nebo heslem</span></div>

    <form method="POST" action="/login">
      <div class="ct-field">
        <label>Uživatelské jméno</label>
        <input type="text" name="username" required autocomplete="username">
      </div>
      <div class="ct-field">
        <label>Heslo</label>
        <input type="password" name="password" required autocomplete="current-password">
      </div>
      <button type="submit" class="ct-btn ct-btn-primary ct-btn-block" style="margin-top:8px;">Přihlásit</button>
    </form>
  </div>
</div>

<script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
<script>
async function loginWithPasskey() {
  const btn = document.getElementById('passkeyBtn');
  const errDiv = document.getElementById('passkey-error');
  errDiv.style.display = 'none';
  btn.disabled = true;
  btn.textContent = 'Čekám na ověření…';
  try {
    const optRes = await fetch('/auth/passkey/login-options');
    const options = await optRes.json();
    const assertion = await SimpleWebAuthnBrowser.startAuthentication({ optionsJSON: options });
    const verRes = await fetch('/auth/passkey/login-verify', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(assertion)
    });
    const result = await verRes.json();
    if (result.verified) { window.location.href = '/'; }
    else { throw new Error('failed'); }
  } catch(err) {
    errDiv.textContent = err.name === 'NotAllowedError' ? 'Ověření bylo zrušeno.' : 'Přihlášení pomocí Face ID selhalo.';
    errDiv.style.display = 'block';
    btn.disabled = false;
    btn.textContent = '🔑 Face ID / Touch ID';
  }
}
</script>
</body>
</html>
