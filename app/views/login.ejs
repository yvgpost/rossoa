<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Přihlášení - Rossoa Tracker</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="login-page">
    <div class="login-container">
        <div class="login-box">
            <h1>Rossoa Tracker</h1>
            <p class="login-subtitle">Přihlaste se</p>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error"><%= error %></div>
            <% } %>
            <div id="passkey-error" class="alert alert-error" style="display:none;"></div>

            <button type="button" class="btn btn-passkey btn-block" id="passkeyBtn" onclick="loginWithPasskey()">
                🔑 Přihlásit pomocí Face ID / Touch ID
            </button>

            <div class="login-divider"><span>nebo heslem</span></div>

            <form method="POST" action="/login">
                <div class="form-group">
                    <label for="username">Uživatelské jméno</label>
                    <input type="text" id="username" name="username" required autocomplete="username">
                </div>

                <div class="form-group">
                    <label for="password">Heslo</label>
                    <input type="password" id="password" name="password" required autocomplete="current-password">
                </div>

                <button type="submit" class="btn btn-primary btn-block">Přihlásit</button>
            </form>
        </div>
    </div>

    <script src="https://unpkg.com/@simplewebauthn/browser/dist/bundle/index.umd.min.js"></script>
    <script>
        async function loginWithPasskey() {
            const btn = document.getElementById('passkeyBtn');
            const errDiv = document.getElementById('passkey-error');
            errDiv.style.display = 'none';
            btn.disabled = true;
            btn.textContent = 'Čekám na ověření…';

            try {
                const optRes = await fetch('/auth/passkey/login-options');
                const options = await optRes.json();

                const assertion = await SimpleWebAuthnBrowser.startAuthentication({ optionsJSON: options });

                const verRes = await fetch('/auth/passkey/login-verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(assertion),
                });
                const result = await verRes.json();

                if (result.verified) {
                    window.location.href = '/';
                } else {
                    throw new Error('Ověření selhalo');
                }
            } catch (err) {
                errDiv.textContent = err.name === 'NotAllowedError'
                    ? 'Ověření bylo zrušeno.'
                    : 'Přihlášení pomocí Face ID selhalo. Zkuste to znovu nebo použijte heslo.';
                errDiv.style.display = 'block';
                btn.disabled = false;
                btn.textContent = '🔑 Přihlásit pomocí Face ID / Touch ID';
            }
        }
    </script>
</body>
</html>