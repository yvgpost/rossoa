<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Materiály - Rossoa Tracker</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="ct-root">

  <%- include('_header', { pageTitle: 'Materiály', activePage: 'materials' }) %>

  <div class="ct-filter-bar">
    <select onchange="window.location.href='/materials' + (this.value ? '?construction_id=' + this.value : '')">
      <option value="">Všechny stavby</option>
      <% constructions.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= selectedConstruction == c.id ? 'selected' : '' %>><%= c.name %></option>
      <% }); %>
    </select>
  </div>

  <div class="ct-section" style="margin-top:16px;">
    <button class="ct-section-add" onclick="showAddMaterialForm()">
      <span class="ct-add-icon">+</span> Přidat materiál / službu
    </button>

    <% if (materials.length === 0) { %>
      <div class="ct-empty">Žádné materiály nejsou přidány</div>
    <% } else { %>
      <div class="ct-card-list">
        <% materials.forEach(function(m) {
          const hasQty = m.category === 'Material' && m.quantity != null;
          const qtyDisplay = hasQty ? parseFloat(m.quantity).toLocaleString('cs-CZ') + (m.material_unit ? '\u00a0' + m.material_unit : '') : null;
        %>
        <div class="ct-card">
          <div class="ct-card-row">
            <div class="ct-card-main">
              <div class="ct-card-name"><%= m.type %><% if (qtyDisplay) { %>, <%= qtyDisplay %><% } %></div>
              <div class="ct-card-sub"><%= m.construction_name %> · <%= new Date(m.date).toLocaleDateString('cs-CZ') %></div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
              <span class="ct-badge <%= m.category === 'Material' ? 'in-progress' : 'planned' %>"><%= m.category === 'Material' ? 'Materiál' : 'Služba' %></span>
              <div class="ct-card-value"><%= parseFloat(m.price).toLocaleString('cs-CZ') %> Kč</div>
            </div>
          </div>
          <div class="ct-card-actions">
            <button class="ct-edit-btn" style="flex:1;" onclick="editMaterial(<%= m.id %>, <%= m.construction_id %>, '<%= m.date ? new Date(m.date).toISOString().split('T')[0] : '' %>', '<%= m.category %>', '<%= m.type.replace(/'/g, "\\'") %>', <%= m.price %>, <%- m.quantity != null ? m.quantity : 'null' %>)">
              <svg class="ct-edit-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 2l3 3-8 8H3v-3l8-8z"/></svg>
              Upravit
            </button>
            <form method="POST" action="/materials/delete/<%= m.id %>" onsubmit="return confirm('Smazat záznam?');" style="flex:1;">
              <button type="submit" class="ct-del-btn" style="width:100%;">Smazat</button>
            </form>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<!-- Add/Edit Modal -->
<div class="ct-modal-backdrop" id="material-modal">
  <div class="ct-modal">
    <div class="ct-modal-title" id="material-modal-title">Nový materiál / služba</div>
    <form method="POST" action="/materials" onsubmit="return validateMaterialForm()" id="material-form">
      <input type="hidden" name="id" id="form_id">
      <input type="hidden" name="is_custom_type" id="is_custom_type" value="false">

      <div class="ct-field">
        <label>Stavba</label>
        <select name="construction_id" id="construction_id" required>
          <option value="">-- Vyberte stavbu --</option>
          <% constructions.forEach(function(c) { %>
            <option value="<%= c.id %>" <%= selectedConstruction == c.id ? 'selected' : '' %>><%= c.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="ct-field">
        <label>Datum</label>
        <input type="date" name="date" id="date" required>
      </div>
      <div class="ct-field">
        <label>Kategorie</label>
        <select name="category" id="category" required onchange="updateTypeOptions()">
          <option value="">-- Vyberte kategorii --</option>
          <option value="Material">Materiál</option>
          <option value="Sluzba">Služba</option>
        </select>
      </div>
      <div class="ct-field">
        <label>Typ</label>
        <select name="type" id="type" required onchange="handleTypeChange(this)">
          <option value="">-- Vyberte typ --</option>
        </select>
        <div id="custom_type_wrapper" style="display:none;margin-top:8px;">
          <input type="text" name="type_custom" id="type_custom" placeholder="Začněte psát..." list="archived-suggestions" autocomplete="off" oninput="checkArchivedSuggestions(this)">
          <datalist id="archived-suggestions"></datalist>
          <small id="type_help" style="font-size:11px;color:var(--color-text-secondary);margin-top:4px;display:block;"></small>
          <div id="new_unit_wrapper" style="display:none;margin-top:8px;">
            <label style="font-size:12px;color:var(--color-text-secondary);margin-bottom:4px;display:block;">Jednotka nového materiálu</label>
            <select name="new_type_unit" id="new_type_unit" onchange="syncUnitDisplay()">
              <option value="">-- Vyberte jednotku --</option>
              <option value="ks">ks (kusy)</option>
              <option value="m">m (metr)</option>
              <option value="m²">m²</option>
              <option value="m³">m³</option>
              <option value="kg">kg (kilogram)</option>
              <option value="t">t (tuna)</option>
              <option value="l">l (litr)</option>
              <option value="bm">bm (běžný metr)</option>
            </select>
          </div>
        </div>
      </div>
      <div id="quantity_unit_row" style="display:none;">
        <div class="ct-field">
          <label>Množství</label>
          <input type="number" name="quantity" id="quantity" step="0.001">
        </div>
        <div class="ct-field">
          <label>Jednotka</label>
          <input type="text" id="unit_display" readonly>
        </div>
      </div>
      <div class="ct-field">
        <label>Cena (Kč)</label>
        <input type="number" name="price" id="price" step="0.01" min="0.01" required>
      </div>
      <div class="ct-modal-actions">
        <button type="button" class="ct-btn" onclick="hideMaterialForm()">Zrušit</button>
        <button type="submit" class="ct-btn ct-btn-primary">Uložit</button>
      </div>
    </form>
  </div>
</div>

<script src="/app.js"></script>
<script>
const materialTypes = <%- JSON.stringify(materialTypes.map(t => ({ name: t.name, unit: t.unit || '' }))) %>;
const materialTypeNames = materialTypes.map(t => t.name);
const serviceTypes = <%- JSON.stringify(serviceTypes.map(t => t.name)) %>;
let currentCategory = '';
let archivedSuggestions = [];
let archivedSearchTimeout;

function showAddMaterialForm() {
  document.getElementById('form_id').value = '';
  document.getElementById('material-modal-title').textContent = 'Nový materiál / služba';
  document.getElementById('date').value = new Date().toLocaleDateString('en-CA');
  document.getElementById('material-modal').classList.add('show');
}

function hideMaterialForm() {
  document.getElementById('material-modal').classList.remove('show');
}

document.getElementById('material-modal').addEventListener('click', function(e) {
  if (e.target === this) hideMaterialForm();
});

function updateTypeOptions() {
  const category = document.getElementById('category').value;
  const typeSelect = document.getElementById('type');
  currentCategory = category;
  resetCustomTypeInput();
  resetQuantityUnit();
  typeSelect.innerHTML = '<option value="">-- Vyberte typ --</option>';
  if (category === 'Material') {
    materialTypes.forEach(t => { typeSelect.innerHTML += `<option value="${t.name}">${t.name}</option>`; });
    typeSelect.innerHTML += '<option value="__new__">+ Přidat nový</option>';
  } else if (category === 'Sluzba') {
    serviceTypes.forEach(t => { typeSelect.innerHTML += `<option value="${t}">${t}</option>`; });
    typeSelect.innerHTML += '<option value="__new__">+ Přidat nový</option>';
  }
  document.getElementById('quantity_unit_row').style.display = 'none';
}

function resetCustomTypeInput() {
  document.getElementById('custom_type_wrapper').style.display = 'none';
  document.getElementById('type_custom').value = '';
  document.getElementById('type_help').textContent = '';
  document.getElementById('type_help').style.color = '';
  document.getElementById('archived-suggestions').innerHTML = '';
  archivedSuggestions = [];
  document.getElementById('is_custom_type').value = 'false';
  document.getElementById('new_unit_wrapper').style.display = 'none';
  document.getElementById('new_type_unit').value = '';
}

function resetQuantityUnit() {
  document.getElementById('quantity').value = '';
  document.getElementById('unit_display').value = '';
}

function syncUnitDisplay() {
  document.getElementById('unit_display').value = document.getElementById('new_type_unit').value;
}

function handleTypeChange(select) {
  const customWrapper = document.getElementById('custom_type_wrapper');
  const isCustom = document.getElementById('is_custom_type');
  const quantityRow = document.getElementById('quantity_unit_row');
  const unitDisplay = document.getElementById('unit_display');
  const newUnitWrapper = document.getElementById('new_unit_wrapper');

  if (select.value === '__new__') {
    customWrapper.style.display = 'block';
    document.getElementById('type_custom').value = '';
    document.getElementById('type_help').textContent = '';
    archivedSuggestions = [];
    isCustom.value = 'true';
    document.getElementById('type_custom').focus();
    if (currentCategory === 'Material') {
      newUnitWrapper.style.display = 'block';
      quantityRow.style.display = 'block';
      unitDisplay.value = '';
    } else {
      newUnitWrapper.style.display = 'none';
      quantityRow.style.display = 'none';
    }
  } else if (select.value) {
    customWrapper.style.display = 'none';
    isCustom.value = 'false';
    newUnitWrapper.style.display = 'none';
    if (currentCategory === 'Material') {
      const typeData = materialTypes.find(t => t.name === select.value);
      unitDisplay.value = typeData ? (typeData.unit || '') : '';
      quantityRow.style.display = 'block';
    }
  } else {
    customWrapper.style.display = 'none';
    isCustom.value = 'false';
    newUnitWrapper.style.display = 'none';
    quantityRow.style.display = 'none';
    unitDisplay.value = '';
  }
}

function checkArchivedSuggestions(input) {
  clearTimeout(archivedSearchTimeout);
  const datalist = document.getElementById('archived-suggestions');
  const helpText = document.getElementById('type_help');
  if (input.value.length < 2) {
    datalist.innerHTML = ''; archivedSuggestions = [];
    helpText.textContent = ''; helpText.style.color = '';
    return;
  }
  const activeNames = currentCategory === 'Material' ? materialTypeNames : serviceTypes;
  const activeMatch = activeNames.find(t => t.toLowerCase() === input.value.trim().toLowerCase());
  if (activeMatch) {
    datalist.innerHTML = ''; archivedSuggestions = [];
    helpText.textContent = `Typ "${activeMatch}" již existuje. Vyberte ho výše.`;
    helpText.style.color = 'var(--red)';
    return;
  } else { helpText.style.color = ''; }
  archivedSearchTimeout = setTimeout(async () => {
    try {
      const res = await fetch(`/api/search-types?q=${encodeURIComponent(input.value)}&category=${currentCategory}`);
      const results = await res.json();
      datalist.innerHTML = '';
      archivedSuggestions = results.map(r => r.name);
      if (results.length > 0) {
        helpText.textContent = 'Vyberte archivovanou položku nebo zadejte nový typ.';
        results.forEach(r => { const o = document.createElement('option'); o.value = r.name; datalist.appendChild(o); });
      } else { helpText.textContent = ''; archivedSuggestions = []; }
    } catch(e) {}
  }, 300);
}

function validateMaterialForm() {
  const customWrapper = document.getElementById('custom_type_wrapper');
  const typeCustom = document.getElementById('type_custom');
  if (customWrapper.style.display !== 'none') {
    const val = typeCustom.value.trim();
    if (!val) { typeCustom.focus(); return false; }
    const activeNames = currentCategory === 'Material' ? materialTypeNames : serviceTypes;
    if (activeNames.find(t => t.toLowerCase() === val.toLowerCase())) {
      alert('Typ již existuje. Vyberte ho ze seznamu.'); typeCustom.focus(); return false;
    }
    if (archivedSuggestions.find(a => a.toLowerCase() === val.toLowerCase())) {
      alert('Vyberte archivovaný typ z návrhů.'); return false;
    }
    if (currentCategory === 'Material' && !document.getElementById('new_type_unit').value) {
      alert('Prosím vyberte jednotku.'); return false;
    }
  }
  if (currentCategory === 'Material' && document.getElementById('quantity_unit_row').style.display !== 'none') {
    const qty = document.getElementById('quantity').value;
    if (!qty || parseFloat(qty) <= 0) { alert('Prosím zadejte množství.'); document.getElementById('quantity').focus(); return false; }
  }
  return true;
}

function editMaterial(id, constructionId, date, category, type, price, quantity) {
  document.getElementById('form_id').value = id;
  document.getElementById('material-modal-title').textContent = 'Upravit materiál / službu';
  document.getElementById('construction_id').value = constructionId;
  document.getElementById('date').value = date;
  document.getElementById('price').value = price;
  document.getElementById('category').value = category;
  updateTypeOptionsForEdit(category, type, quantity);
  document.getElementById('material-modal').classList.add('show');
}

function updateTypeOptionsForEdit(category, selectedType, quantity) {
  const typeSelect = document.getElementById('type');
  const customWrapper = document.getElementById('custom_type_wrapper');
  const typeCustom = document.getElementById('type_custom');
  const quantityRow = document.getElementById('quantity_unit_row');
  const unitDisplay = document.getElementById('unit_display');
  currentCategory = category;

  customWrapper.style.display = 'none';
  document.getElementById('new_unit_wrapper').style.display = 'none';
  typeSelect.innerHTML = '<option value="">-- Vyberte typ --</option>';

  if (category === 'Material') {
    materialTypes.forEach(t => { typeSelect.innerHTML += `<option value="${t.name}">${t.name}</option>`; });
  } else {
    serviceTypes.forEach(t => { typeSelect.innerHTML += `<option value="${t}">${t}</option>`; });
  }
  typeSelect.innerHTML += '<option value="__new__">+ Přidat nový</option>';

  const allNames = category === 'Material' ? materialTypeNames : serviceTypes;
  if (allNames.includes(selectedType)) {
    typeSelect.value = selectedType;
    if (category === 'Material') {
      const typeData = materialTypes.find(t => t.name === selectedType);
      unitDisplay.value = typeData ? (typeData.unit || '') : '';
      quantityRow.style.display = 'block';
      document.getElementById('quantity').value = quantity != null ? quantity : '';
    }
  } else {
    typeSelect.value = '';
    customWrapper.style.display = 'block';
    typeCustom.value = selectedType;
    document.getElementById('is_custom_type').value = 'true';
    if (category === 'Material') {
      quantityRow.style.display = 'block';
      document.getElementById('quantity').value = quantity != null ? quantity : '';
    }
  }
}
</script>
</body>
</html>
