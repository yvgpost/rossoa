<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Přehled - Rossoa Tracker</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="ct-root">

  <%- include('_header', { pageTitle: 'Přehled', activePage: 'dashboard' }) %>

  <div class="ct-section" style="margin-top:16px;">
    <div class="ct-section-label">Stavby</div>
    <div class="ct-stat-grid">
      <div class="ct-stat green"><div class="ct-stat-val"><%= inProgress %></div><div class="ct-stat-lbl">Probíhající</div></div>
      <div class="ct-stat blue"><div class="ct-stat-val"><%= planned %></div><div class="ct-stat-lbl">Plánované</div></div>
      <div class="ct-stat grey"><div class="ct-stat-val"><%= finished %></div><div class="ct-stat-lbl">Dokončené</div></div>
    </div>
    <div class="ct-stat-grid-2">
      <div class="ct-stat normal"><div class="ct-stat-val"><%= activeWorkers %></div><div class="ct-stat-lbl">Zaměstnanci</div></div>
      <div class="ct-stat accent money"><div class="ct-stat-val"><%= totalPrice.toLocaleString('cs-CZ') %> Kč</div><div class="ct-stat-lbl">Celková cena</div></div>
    </div>
    <div class="ct-stat-grid-2">
      <div class="ct-stat red money"><div class="ct-stat-val"><%= totalExpenses.toLocaleString('cs-CZ') %> Kč</div><div class="ct-stat-lbl">Celkové náklady</div></div>
      <div class="ct-stat money <%= totalProfit >= 0 ? 'green' : 'red' %>"><div class="ct-stat-val"><%= totalProfit.toLocaleString('cs-CZ') %> Kč</div><div class="ct-stat-lbl">Celkový zisk</div></div>
    </div>
  </div>

  <div class="ct-section" style="margin-top:20px;">
    <div class="ct-section-label">Aktivní a plánované stavby</div>
    <% if (constructions.length === 0) { %>
      <div class="ct-empty">Žádné aktivní nebo plánované stavby</div>
    <% } else { %>
      <div class="ct-project-list">
        <% constructions.forEach(function(c) {
          const stateClass = c.state === 'In progress' ? 'active' : c.state === 'Planned' ? 'planned' : 'finished';
          const stateLabel = c.state === 'In progress' ? 'Aktivní' : c.state === 'Planned' ? 'Plánovaná' : 'Dokončená';
          const totalExp = parseFloat(c.total_expenses || 0);
          const price = parseFloat(c.price || 0);
          const profit = price - totalExp;
        %>
        <div class="ct-project" id="proj-<%= c.id %>">
          <div class="ct-project-header" onclick="toggleProject(<%= c.id %>)">
            <span class="ct-status-dot <%= stateClass %>"></span>
            <span class="ct-project-name"><%= c.name %></span>
            <span class="ct-project-price"><%= price.toLocaleString('cs-CZ') %> Kč</span>
            <svg class="ct-chevron" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6l4 4 4-4"/></svg>
          </div>
          <div class="ct-project-body">
            <div class="ct-divider"></div>
            <span class="ct-tag <%= stateClass %>"><%= stateLabel %></span>
            <div class="ct-detail-grid">
              <div><div class="ct-detail-lbl">Datum zahájení</div><div class="ct-detail-val"><%= c.beginning_date ? new Date(c.beginning_date).toLocaleDateString('cs-CZ') : '—' %></div></div>
              <div><div class="ct-detail-lbl">Zákazník</div><div class="ct-detail-val"><%= c.customer || '—' %></div></div>
              <div><div class="ct-detail-lbl">Cena stavby</div><div class="ct-detail-val amber"><%= price.toLocaleString('cs-CZ') %> Kč</div></div>
              <div><div class="ct-detail-lbl">Celkové náklady</div><div class="ct-detail-val red"><%= totalExp.toLocaleString('cs-CZ') %> Kč</div></div>
              <div><div class="ct-detail-lbl">Celkový zisk</div><div class="ct-detail-val <%= profit >= 0 ? 'green' : 'red' %>"><%= profit.toLocaleString('cs-CZ') %> Kč</div></div>
              <div><div class="ct-detail-lbl">Náklady materiály/služby</div><div class="ct-detail-val red"><%= parseFloat(c.materials_total).toLocaleString('cs-CZ') %> Kč</div></div>
              <div></div>
              <div><div class="ct-detail-lbl">Náklady práce</div><div class="ct-detail-val red"><%= parseFloat(c.works_total).toLocaleString('cs-CZ') %> Kč</div></div>
            </div>
            <div class="ct-btn-row">
              <button class="ct-edit-btn" onclick="openEditModal(<%= c.id %>, '<%= c.name.replace(/'/g, "\\'") %>', '<%= (c.customer||'').replace(/'/g, "\\'") %>', '<%= c.beginning_date ? new Date(c.beginning_date).toISOString().split('T')[0] : '' %>', '<%= c.end_date ? new Date(c.end_date).toISOString().split('T')[0] : '' %>', <%= price %>)">
                <svg class="ct-edit-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 2l3 3-8 8H3v-3l8-8z"/></svg>
                Upravit
              </button>
              <button class="ct-add-btn" onclick="openRecordModal(<%= c.id %>)">
                <span class="ct-add-icon">+</span> Přidat záznam
              </button>
            </div>
            <div class="ct-records">
              <div class="ct-records-label">Poslední 10 záznamů</div>
              <% if (c.records && c.records.length > 0) { %>
                <% c.records.forEach(function(r) { %>
                  <div class="ct-record-item">
                    <div style="flex:1;min-width:0;">
                      <div class="ct-record-desc"><%= r.description %></div>
                      <div class="ct-record-date"><%= r.date ? new Date(r.date).toLocaleDateString('cs-CZ') : '' %></div>
                    </div>
                    <div class="ct-record-amt out" style="margin-right:10px;">−<%= parseFloat(r.price).toLocaleString('cs-CZ') %> Kč</div>
                    <button class="ct-record-edit-btn" onclick="openRecordEditModal(<%= r.id %>, '<%= r.kind %>', '<%= r.construction_id %>', '<%= r.raw_category %>', '<%= r.raw_type.replace(/'/g, "\\'") %>', '<%= r.date ? new Date(r.date).toISOString().split('T')[0] : '' %>', <%= r.price %>, <%= r.quantity != null ? r.quantity : 'null' %>, '<%= r.worker_id || '' %>')" title="Upravit">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16"><path d="M11 2l3 3-8 8H3v-3l8-8z"/></svg>
                    </button>
                  </div>
                <% }); %>
              <% } else { %>
                <div style="font-size:15px;color:var(--color-text-secondary);padding:8px 0;">Žádné záznamy</div>
              <% } %>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<!-- Record Modal -->
<div class="ct-modal-backdrop" id="record-modal">
  <div class="ct-modal">
    <div class="ct-modal-title">Přidat záznam</div>

    <div id="rec-step-type">
      <div class="ct-type-selector">
        <button class="ct-type-option" id="opt-material" onclick="selectRecordType('material')">
          Materiál<br>/ Služba
        </button>
        <button class="ct-type-option" id="opt-work" onclick="selectRecordType('work')">
          Práce
        </button>
      </div>
      <div class="ct-modal-actions">
        <button class="ct-btn" style="width:100%;" onclick="closeRecordModal()">Zrušit</button>
      </div>
    </div>

    <div id="rec-fields-material" style="display:none;">
      <form method="POST" action="/materials" onsubmit="return validateAddMatForm()" id="add-mat-form">
        <input type="hidden" name="redirect_to" value="/">
        <input type="hidden" name="construction_id" id="add-mat-construction">
        <input type="hidden" name="is_custom_type" id="add-mat-is-custom" value="false">
        <div class="ct-field">
          <label>Datum</label>
          <input type="date" name="date" id="add-mat-date" required>
        </div>
        <div class="ct-field">
          <label>Kategorie</label>
          <select name="category" id="add-mat-category" required onchange="addMatUpdateTypeOptions()">
            <option value="">-- Vyberte kategorii --</option>
            <option value="Material">Materiál</option>
            <option value="Sluzba">Služba</option>
          </select>
        </div>
        <div class="ct-field">
          <label>Typ</label>
          <select name="type" id="add-mat-type" required onchange="addMatHandleTypeChange(this)">
            <option value="">-- Vyberte typ --</option>
          </select>
          <div id="add-mat-custom-wrapper" style="display:none;margin-top:8px;">
            <input type="text" name="type_custom" id="add-mat-type-custom" placeholder="Začněte psát..." list="add-mat-archived-suggestions" autocomplete="off" oninput="addMatCheckArchivedSuggestions(this)">
            <datalist id="add-mat-archived-suggestions"></datalist>
            <small id="add-mat-type-help" style="font-size:11px;color:var(--color-text-secondary);margin-top:4px;display:block;"></small>
            <div id="add-mat-new-unit-wrapper" style="display:none;margin-top:8px;">
              <label style="font-size:12px;color:var(--color-text-secondary);margin-bottom:4px;display:block;">Jednotka nového materiálu</label>
              <select name="new_type_unit" id="add-mat-new-type-unit" onchange="addMatSyncUnitDisplay()">
                <option value="">-- Vyberte jednotku --</option>
                <option value="ks">ks (kusy)</option>
                <option value="m">m (metr)</option>
                <option value="m²">m²</option>
                <option value="m³">m³</option>
                <option value="kg">kg (kilogram)</option>
                <option value="t">t (tuna)</option>
                <option value="l">l (litr)</option>
                <option value="bm">bm (běžný metr)</option>
              </select>
            </div>
          </div>
        </div>
        <div id="add-mat-qty-row" style="display:none;">
          <div class="ct-field">
            <label>Množství</label>
            <input type="number" name="quantity" id="add-mat-quantity" step="0.001">
          </div>
          <div class="ct-field">
            <label>Jednotka</label>
            <input type="text" id="add-mat-unit-display" readonly>
          </div>
        </div>
        <div class="ct-field">
          <label>Cena (Kč)</label>
          <input type="number" name="price" id="add-mat-price" step="0.01" min="0.01" required>
        </div>
        <div class="ct-modal-actions">
          <button type="button" class="ct-btn" onclick="closeRecordModal()">Zrušit</button>
          <button type="submit" class="ct-btn ct-btn-primary">Uložit</button>
        </div>
      </form>
    </div>

    <div id="rec-fields-work" style="display:none;">
      <form method="POST" action="/works">
        <input type="hidden" name="redirect_to" value="/">
        <input type="hidden" name="construction_id" id="add-w-construction">
        <div class="ct-field">
          <label>Typ práce</label>
          <input type="text" name="type" id="rec-work-type" placeholder="např. Zednické práce" required>
        </div>
        <div class="ct-field">
          <label>Zaměstnanec</label>
          <select name="worker_id" id="rec-worker" required>
            <option value="">-- Vyberte zaměstnance --</option>
            <% workers.forEach(function(w) { %>
              <option value="<%= w.id %>"><%= w.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="ct-field">
          <label>Datum</label>
          <input type="date" name="date" id="rec-date-work" required>
        </div>
        <div class="ct-field">
          <label>Cena (Kč)</label>
          <input type="number" name="price" id="rec-price-work" step="0.01" min="0" required>
        </div>
        <div class="ct-modal-actions">
          <button type="button" class="ct-btn" onclick="closeRecordModal()">Zrušit</button>
          <button type="submit" class="ct-btn ct-btn-primary">Uložit</button>
        </div>
      </form>
    </div>
  </div>
</div>

