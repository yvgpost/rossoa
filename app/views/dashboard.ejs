<script src="/app.js"></script>
<script>
let activeConstructionId = null;
let currentRecordType = null;

function toggleProject(id) {
  const el = document.getElementById('proj-' + id);
  el.classList.toggle('open');
}

function openRecordModal(id) {
  activeConstructionId = id;
  currentRecordType = null;
  document.getElementById('rec-step-type').style.display = 'block';
  document.getElementById('rec-fields-material').style.display = 'none';
  document.getElementById('rec-fields-work').style.display = 'none';
  document.getElementById('opt-material').classList.remove('selected');
  document.getElementById('opt-work').classList.remove('selected');
  const today = new Date().toLocaleDateString('en-CA');
  document.getElementById('add-mat-construction').value = id;
  document.getElementById('add-w-construction').value = id;
  document.getElementById('add-mat-date').value = today;
  document.getElementById('rec-date-work').value = today;
  document.getElementById('add-mat-price').value = '';
  document.getElementById('rec-price-work').value = '';
  document.getElementById('rec-work-type').value = '';
  document.getElementById('add-mat-category').value = '';
  addMatResetTypeSelect();
  document.getElementById('record-modal').classList.add('show');
}

function selectRecordType(type) {
  currentRecordType = type;
  document.getElementById('opt-material').classList.toggle('selected', type === 'material');
  document.getElementById('opt-work').classList.toggle('selected', type === 'work');
  document.getElementById('rec-step-type').style.display = 'none';
  if (type === 'material') {
    document.getElementById('rec-fields-material').style.display = 'block';
    document.getElementById('rec-fields-work').style.display = 'none';
  } else {
    document.getElementById('rec-fields-work').style.display = 'block';
    document.getElementById('rec-fields-material').style.display = 'none';
  }
}

function closeRecordModal() {
  document.getElementById('record-modal').classList.remove('show');
}

document.getElementById('record-modal').addEventListener('click', function(e) {
  if (e.target === this) closeRecordModal();
});

// ---- Add record: material form full logic ----
let addMatCurrentCategory = '';
let addMatArchivedSuggestions = [];
let addMatArchivedSearchTimeout;

function addMatResetTypeSelect() {
  const sel = document.getElementById('add-mat-type');
  sel.innerHTML = '<option value="">-- Vyberte typ --</option>';
  document.getElementById('add-mat-custom-wrapper').style.display = 'none';
  document.getElementById('add-mat-type-custom').value = '';
  document.getElementById('add-mat-type-help').textContent = '';
  document.getElementById('add-mat-archived-suggestions').innerHTML = '';
  addMatArchivedSuggestions = [];
  document.getElementById('add-mat-is-custom').value = 'false';
  document.getElementById('add-mat-new-unit-wrapper').style.display = 'none';
  document.getElementById('add-mat-new-type-unit').value = '';
  document.getElementById('add-mat-qty-row').style.display = 'none';
  document.getElementById('add-mat-quantity').value = '';
  document.getElementById('add-mat-unit-display').value = '';
}

function addMatUpdateTypeOptions() {
  const category = document.getElementById('add-mat-category').value;
  addMatCurrentCategory = category;
  addMatResetTypeSelect();
  const sel = document.getElementById('add-mat-type');
  sel.innerHTML = '<option value="">-- Vyberte typ --</option>';
  if (category === 'Material') {
    dmMaterialTypes.forEach(t => { sel.innerHTML += `<option value="${t.name}">${t.name}</option>`; });
    sel.innerHTML += '<option value="__new__">+ Přidat nový</option>';
  } else if (category === 'Sluzba') {
    dmServiceTypes.forEach(t => { sel.innerHTML += `<option value="${t}">${t}</option>`; });
    sel.innerHTML += '<option value="__new__">+ Přidat nový</option>';
  }
}

function addMatHandleTypeChange(select) {
  const customWrapper = document.getElementById('add-mat-custom-wrapper');
  const isCustom = document.getElementById('add-mat-is-custom');
  const qtyRow = document.getElementById('add-mat-qty-row');
  const unitDisplay = document.getElementById('add-mat-unit-display');
  const newUnitWrapper = document.getElementById('add-mat-new-unit-wrapper');
  if (select.value === '__new__') {
    customWrapper.style.display = 'block';
    document.getElementById('add-mat-type-custom').value = '';
    document.getElementById('add-mat-type-help').textContent = '';
    addMatArchivedSuggestions = [];
    isCustom.value = 'true';
    document.getElementById('add-mat-type-custom').focus();
    if (addMatCurrentCategory === 'Material') { newUnitWrapper.style.display = 'block'; qtyRow.style.display = 'block'; unitDisplay.value = ''; }
    else { newUnitWrapper.style.display = 'none'; qtyRow.style.display = 'none'; }
  } else if (select.value) {
    customWrapper.style.display = 'none';
    isCustom.value = 'false';
    newUnitWrapper.style.display = 'none';
    if (addMatCurrentCategory === 'Material') {
      const typeData = dmMaterialTypes.find(t => t.name === select.value);
      unitDisplay.value = typeData ? (typeData.unit || '') : '';
      qtyRow.style.display = 'block';
    }
  } else {
    customWrapper.style.display = 'none';
    isCustom.value = 'false';
    newUnitWrapper.style.display = 'none';
    qtyRow.style.display = 'none';
    unitDisplay.value = '';
  }
}

function addMatSyncUnitDisplay() {
  document.getElementById('add-mat-unit-display').value = document.getElementById('add-mat-new-type-unit').value;
}

function addMatCheckArchivedSuggestions(input) {
  clearTimeout(addMatArchivedSearchTimeout);
  const datalist = document.getElementById('add-mat-archived-suggestions');
  const helpText = document.getElementById('add-mat-type-help');
  if (input.value.length < 2) { datalist.innerHTML = ''; addMatArchivedSuggestions = []; helpText.textContent = ''; helpText.style.color = ''; return; }
  const activeNames = addMatCurrentCategory === 'Material' ? dmMaterialTypeNames : dmServiceTypes;
  const activeMatch = activeNames.find(t => t.toLowerCase() === input.value.trim().toLowerCase());
  if (activeMatch) { datalist.innerHTML = ''; addMatArchivedSuggestions = []; helpText.textContent = `Typ "${activeMatch}" již existuje. Vyberte ho výše.`; helpText.style.color = 'var(--red)'; return; }
  else { helpText.style.color = ''; }
  addMatArchivedSearchTimeout = setTimeout(async () => {
    try {
      const res = await fetch(`/api/search-types?q=${encodeURIComponent(input.value)}&category=${addMatCurrentCategory}`);
      const results = await res.json();
      datalist.innerHTML = '';
      addMatArchivedSuggestions = results.map(r => r.name);
      if (results.length > 0) {
        helpText.textContent = 'Vyberte archivovanou položku nebo zadejte nový typ.';
        results.forEach(r => { const o = document.createElement('option'); o.value = r.name; datalist.appendChild(o); });
      } else { helpText.textContent = ''; addMatArchivedSuggestions = []; }
    } catch(e) {}
  }, 300);
}

function validateAddMatForm() {
  const customWrapper = document.getElementById('add-mat-custom-wrapper');
  const typeCustom = document.getElementById('add-mat-type-custom');
  if (customWrapper.style.display !== 'none') {
    const val = typeCustom.value.trim();
    if (!val) { typeCustom.focus(); return false; }
    const activeNames = addMatCurrentCategory === 'Material' ? dmMaterialTypeNames : dmServiceTypes;
    if (activeNames.find(t => t.toLowerCase() === val.toLowerCase())) { alert('Typ již existuje. Vyberte ho ze seznamu.'); typeCustom.focus(); return false; }
    if (addMatArchivedSuggestions.find(a => a.toLowerCase() === val.toLowerCase())) { alert('Vyberte archivovaný typ z návrhů.'); return false; }
    if (addMatCurrentCategory === 'Material' && !document.getElementById('add-mat-new-type-unit').value) { alert('Prosím vyberte jednotku.'); return false; }
  }
  if (addMatCurrentCategory === 'Material' && document.getElementById('add-mat-qty-row').style.display !== 'none') {
    const qty = document.getElementById('add-mat-quantity').value;
    if (!qty || parseFloat(qty) <= 0) { alert('Prosím zadejte množství.'); document.getElementById('add-mat-quantity').focus(); return false; }
  }
  return true;
}

// ---- Record Edit: dispatch by kind ----
const dmMaterialTypes = <%- JSON.stringify(materialTypes.map(t => ({ name: t.name, unit: t.unit || '' }))) %>;
const dmMaterialTypeNames = dmMaterialTypes.map(t => t.name);
const dmServiceTypes = <%- JSON.stringify(serviceTypes.map(t => t.name)) %>;
let dmCurrentCategory = '';
let dmArchivedSuggestions = [];
let dmArchivedSearchTimeout;

function openRecordEditModal(id, kind, constructionId, rawCategory, rawType, date, price, quantity, workerId) {
  if (kind === 'work') {
    document.getElementById('dm-w-id').value = id;
    document.getElementById('dm-w-construction').value = constructionId;
    document.getElementById('dm-w-type').value = rawType;
    document.getElementById('dm-w-worker').value = workerId || '';
    document.getElementById('dm-w-date').value = date;
    document.getElementById('dm-w-price').value = price;
    document.getElementById('dm-work-modal').classList.add('show');
  } else {
    document.getElementById('dm-mat-id').value = id;
    document.getElementById('dm-mat-construction').value = constructionId;
    document.getElementById('dm-mat-date').value = date;
    document.getElementById('dm-mat-price').value = price;
    document.getElementById('dm-mat-category').value = rawCategory;
    dmUpdateTypeOptionsForEdit(rawCategory, rawType, quantity);
    document.getElementById('dm-mat-modal').classList.add('show');
  }
}

function closeDmMatModal() { document.getElementById('dm-mat-modal').classList.remove('show'); }
function closeDmWorkModal() { document.getElementById('dm-work-modal').classList.remove('show'); }

document.getElementById('dm-mat-modal').addEventListener('click', function(e) { if (e.target === this) closeDmMatModal(); });
document.getElementById('dm-work-modal').addEventListener('click', function(e) { if (e.target === this) closeDmWorkModal(); });

function dmUpdateTypeOptions() {
  const category = document.getElementById('dm-mat-category').value;
  const sel = document.getElementById('dm-mat-type');
  dmCurrentCategory = category;
  dmResetCustomTypeInput();
  dmResetQuantityUnit();
  sel.innerHTML = '<option value="">-- Vyberte typ --</option>';
  if (category === 'Material') {
    dmMaterialTypes.forEach(t => { sel.innerHTML += `<option value="${t.name}">${t.name}</option>`; });
    sel.innerHTML += '<option value="__new__">+ Přidat nový</option>';
  } else if (category === 'Sluzba') {
    dmServiceTypes.forEach(t => { sel.innerHTML += `<option value="${t}">${t}</option>`; });
    sel.innerHTML += '<option value="__new__">+ Přidat nový</option>';
  }
  document.getElementById('dm-mat-qty-row').style.display = 'none';
}

function dmUpdateTypeOptionsForEdit(category, selectedType, quantity) {
  const sel = document.getElementById('dm-mat-type');
  const customWrapper = document.getElementById('dm-mat-custom-wrapper');
  const typeCustom = document.getElementById('dm-mat-type-custom');
  const qtyRow = document.getElementById('dm-mat-qty-row');
  const unitDisplay = document.getElementById('dm-mat-unit-display');
  dmCurrentCategory = category;
  customWrapper.style.display = 'none';
  document.getElementById('dm-mat-new-unit-wrapper').style.display = 'none';
  sel.innerHTML = '<option value="">-- Vyberte typ --</option>';
  if (category === 'Material') {
    dmMaterialTypes.forEach(t => { sel.innerHTML += `<option value="${t.name}">${t.name}</option>`; });
  } else {
    dmServiceTypes.forEach(t => { sel.innerHTML += `<option value="${t}">${t}</option>`; });
  }
  sel.innerHTML += '<option value="__new__">+ Přidat nový</option>';
  const allNames = category === 'Material' ? dmMaterialTypeNames : dmServiceTypes;
  if (allNames.includes(selectedType)) {
    sel.value = selectedType;
    if (category === 'Material') {
      const typeData = dmMaterialTypes.find(t => t.name === selectedType);
      unitDisplay.value = typeData ? (typeData.unit || '') : '';
      qtyRow.style.display = 'block';
      document.getElementById('dm-mat-quantity').value = quantity != null ? quantity : '';
    }
  } else {
    sel.value = '';
    customWrapper.style.display = 'block';
    typeCustom.value = selectedType;
    document.getElementById('dm-mat-is-custom').value = 'true';
    if (category === 'Material') {
      qtyRow.style.display = 'block';
      document.getElementById('dm-mat-quantity').value = quantity != null ? quantity : '';
    }
  }
}

function dmHandleTypeChange(select) {
  const customWrapper = document.getElementById('dm-mat-custom-wrapper');
  const isCustom = document.getElementById('dm-mat-is-custom');
  const qtyRow = document.getElementById('dm-mat-qty-row');
  const unitDisplay = document.getElementById('dm-mat-unit-display');
  const newUnitWrapper = document.getElementById('dm-mat-new-unit-wrapper');
  if (select.value === '__new__') {
    customWrapper.style.display = 'block';
    document.getElementById('dm-mat-type-custom').value = '';
    document.getElementById('dm-mat-type-help').textContent = '';
    dmArchivedSuggestions = [];
    isCustom.value = 'true';
    document.getElementById('dm-mat-type-custom').focus();
    if (dmCurrentCategory === 'Material') { newUnitWrapper.style.display = 'block'; qtyRow.style.display = 'block'; unitDisplay.value = ''; }
    else { newUnitWrapper.style.display = 'none'; qtyRow.style.display = 'none'; }
  } else if (select.value) {
    customWrapper.style.display = 'none';
    isCustom.value = 'false';
    newUnitWrapper.style.display = 'none';
    if (dmCurrentCategory === 'Material') {
      const typeData = dmMaterialTypes.find(t => t.name === select.value);
      unitDisplay.value = typeData ? (typeData.unit || '') : '';
      qtyRow.style.display = 'block';
    }
  } else {
    customWrapper.style.display = 'none';
    isCustom.value = 'false';
    newUnitWrapper.style.display = 'none';
    qtyRow.style.display = 'none';
    unitDisplay.value = '';
  }
}

function dmResetCustomTypeInput() {
  document.getElementById('dm-mat-custom-wrapper').style.display = 'none';
  document.getElementById('dm-mat-type-custom').value = '';
  document.getElementById('dm-mat-type-help').textContent = '';
  document.getElementById('dm-mat-type-help').style.color = '';
  document.getElementById('dm-mat-archived-suggestions').innerHTML = '';
  dmArchivedSuggestions = [];
  document.getElementById('dm-mat-is-custom').value = 'false';
  document.getElementById('dm-mat-new-unit-wrapper').style.display = 'none';
  document.getElementById('dm-mat-new-type-unit').value = '';
}

function dmResetQuantityUnit() {
  document.getElementById('dm-mat-quantity').value = '';
  document.getElementById('dm-mat-unit-display').value = '';
}

function dmSyncUnitDisplay() {
  document.getElementById('dm-mat-unit-display').value = document.getElementById('dm-mat-new-type-unit').value;
}

