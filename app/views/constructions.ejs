<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stavby - Rossoa Tracker</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">Rossoa Tracker</a>
            <ul class="nav-menu">
                <li><a href="/">Přehled</a></li>
                <li><a href="/constructions" class="active">Stavby</a></li>
                <li><a href="/materials">Materiály</a></li>
                <li><a href="/works">Práce</a></li>
                <li><a href="/workers">Zaměstnanci</a></li>
                <li><a href="/settings">Nastavení</a></li>
                <li class="nav-user">
                    <span><%= username %></span>
                    <a href="/logout" class="btn-logout">Odhlásit</a>
                </li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <div class="page-header">
            <h1>Stavby</h1>
            <button class="btn btn-primary" onclick="document.getElementById('constructionForm').style.display = 'block'">Přidat stavbu</button>
        </div>

        <div id="constructionForm" class="form-panel" style="display: none;">
            <h3>Nová stavba</h3>
            <form method="POST" action="/constructions">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name">Název stavby</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="customer">Zákazník</label>
                        <input type="text" id="customer" name="customer">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="beginning_date">Datum zahájení</label>
                        <input type="date" id="beginning_date" name="beginning_date">
                    </div>
                    <div class="form-group">
                        <label for="end_date">Datum ukončení</label>
                        <input type="date" id="end_date" name="end_date">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="price">Cena projektu (Kč)</label>
                        <input type="number" id="price" name="price" step="0.01" value="0">
                    </div>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Uložit</button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('constructionForm').style.display = 'none'">Zrušit</button>
                </div>
            </form>
        </div>

        <% if (constructions.length > 0) { %>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Název</th>
                        <th>Zákazník</th>
                        <th>Stav</th>
                        <th>Datum zahájení</th>
                        <th>Datum ukončení</th>
                        <th>Cena</th>
                        <th>Náklady</th>
                        <th>Zisk</th>
                        <th>Akce</th>
                    </tr>
                </thead>
                <tbody>
                    <% constructions.forEach(function(c) { %>
                        <tr>
                            <td><%= c.name %></td>
                            <td><%= c.customer || '-' %></td>
                            <td>
                                <span class="badge badge-<%= c.state === 'Finished' ? 'success' : c.state === 'In progress' ? 'primary' : 'secondary' %>">
                                    <%= c.state %>
                                </span>
                            </td>
                            <td><%= c.beginning_date ? new Date(c.beginning_date).toLocaleDateString('cs-CZ') : '-' %></td>
                            <td><%= c.end_date ? new Date(c.end_date).toLocaleDateString('cs-CZ') : '-' %></td>
                            <td><%= parseFloat(c.price).toLocaleString('cs-CZ') %> Kč</td>
                            <td><%= parseFloat(c.total_expenses || 0).toLocaleString('cs-CZ') %> Kč</td>
                            <td class="<%= c.revenue >= 0 ? 'text-success' : 'text-danger' %>">
                                <%= c.revenue.toLocaleString('cs-CZ') %> Kč
                            </td>
                            <td class="actions">
                                <a href="/materials?construction_id=<%= c.id %>" class="btn btn-small">Materiály</a>
                                <a href="/works?construction_id=<%= c.id %>" class="btn btn-small">Práce</a>
                                <button class="btn btn-small btn-edit" onclick="editConstruction(<%= c.id %>, '<%= c.name %>', '<%= c.customer || '' %>', '<%= c.beginning_date ? c.beginning_date.toISOString().split('T')[0] : '' %>', '<%= c.end_date ? c.end_date.toISOString().split('T')[0] : '' %>', <%= c.price %>)">Upravit</button>
                                <form method="POST" action="/constructions/delete/<%= c.id %>" style="display: inline;" onsubmit="return confirm('Opravdu chcete smazat tuto stavbu?');">
                                    <button type="submit" class="btn btn-small btn-danger">Smazat</button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <p class="empty-state">Žádné stavby nejsou vytvořeny.</p>
        <% } %>
    </main>

    <script>
        function editConstruction(id, name, customer, beginning_date, end_date, price) {
            const form = document.getElementById('constructionForm');
            form.style.display = 'block';
            form.innerHTML = `
                <h3>Upravit stavbu</h3>
                <form method="POST" action="/constructions">
                    <input type="hidden" name="id" value="${id}">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="name">Název stavby</label>
                            <input type="text" id="name" name="name" value="${name}" required>
                        </div>
                        <div class="form-group">
                            <label for="customer">Zákazník</label>
                            <input type="text" id="customer" name="customer" value="${customer}">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="beginning_date">Datum zahájení</label>
                            <input type="date" id="beginning_date" name="beginning_date" value="${beginning_date}">
                        </div>
                        <div class="form-group">
                            <label for="end_date">Datum ukončení</label>
                            <input type="date" id="end_date" name="end_date" value="${end_date}">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="price">Cena projektu (Kč)</label>
                            <input type="number" id="price" name="price" step="0.01" value="${price}">
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Uložit</button>
                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('constructionForm').style.display = 'none'; location.reload();">Zrušit</button>
                    </div>
                </form>
            `;
        }
    </script>
</body>
</html>